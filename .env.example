# Sauron Configuration
PORT=3333
CRON_SCHEDULE=0 8 * * *
DB_PATH=data/sauron.db
DASHBOARD_URL=http://localhost:3333
LOG_LEVEL=info

# === API Keys (shared across all sites) ===

# Cloudflare — https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# GitHub — https://github.com/settings/tokens (needs repo read access)
GITHUB_TOKEN=

# Google Service Account (for Analytics + Search Console)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# PostHog — https://us.posthog.com/settings/project-api-keys
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.posthog.com

# DigitalOcean — https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_TOKEN=

# EAS (Expo) — https://expo.dev/accounts/[account]/settings/access-tokens
EAS_TOKEN=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Sauron <reports@yourdomain.com>
RESEND_TO_EMAIL=you@example.com

# === Sites Configuration ===
# JSON array of site objects. Each site declares which services it uses.
# Example:
# SITES='[{"id":"mysite","name":"My Site","url":"https://mysite.com","cloudflare":{"zoneId":"abc123"},"github":{"repo":"owner/repo"},"googleAnalytics":{"propertyId":"123456"},"googleSearchConsole":{"siteUrl":"https://mysite.com"},"posthog":{"projectId":"12345"},"digitalocean":{"appId":"app-id"},"resend":{},"eas":{"projectId":"expo-project-id"}}]'
SITES=
